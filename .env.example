SESSION_PATH=/
SESSION_DOMAIN=.billable.test

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
CASHIER_CURRENCY=usd

MAIL_MAILER=log
MAIL_SCHEME=null
